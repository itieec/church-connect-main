# Copy to apps/web/.env.local and fill from Firebase Console → Project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ieec-ya-connect.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ieec-ya-connect
VITE_FIREBASE_STORAGE_BUCKET=ieec-ya-connect.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to talk to local emulators
VITE_USE_EMULATORS=false

# Public registration org (single-org MVP)
VITE_PUBLIC_ORG_ID=ieec_ya
