rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function accountPath() {
      return /databases/$(database)/documents/userAccounts/$(request.auth.uid);
    }

    function account() {
      return get(accountPath()).data;
    }

    function hasAccount() {
      return isSignedIn() && exists(accountPath());
    }

    function accountActive() {
      return hasAccount() && account().accountStatus == 'active';
    }

    function orgId() {
      return account().organizationId;
    }

    function personId() {
      return account().personId;
    }

    function sameOrg(data) {
      return data.organizationId == orgId();
    }

    function hasPlatformAdmin() {
      return accountActive()
        && account().keys().hasAny(['isSuperAdmin'])
        && account().isSuperAdmin == true;
    }

    function canReadOrg(data) {
      return accountActive() && sameOrg(data);
    }

    function canWriteOrgAdmin(data) {
      return hasPlatformAdmin() && sameOrg(data);
    }

    // Phase B interim: signed-in org members may write Follow-Up ops they own.
    // Fine-grained permission keys will move to custom claims / Functions later.
    function isOrgMember() {
      return accountActive();
    }

    function isAssignee(data) {
      return data.keys().hasAny(['assignedPersonId'])
        && data.assignedPersonId == personId();
    }

    function isReporter(data) {
      return data.keys().hasAny(['submittedByPersonId'])
        && data.submittedByPersonId == personId();
    }

    match /organizations/{organizationId} {
      allow read: if accountActive() && organizationId == account().organizationId;
      allow write: if hasPlatformAdmin();
    }

    match /people/{pid} {
      allow read: if canReadOrg(resource.data);
      allow create, update: if canWriteOrgAdmin(request.resource.data)
        || (isOrgMember() && sameOrg(request.resource.data));
      allow delete: if false;
    }

    match /userAccounts/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasPlatformAdmin());
      allow create: if hasPlatformAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.accountStatus == 'active'
            && request.resource.data.personId is string
            && request.resource.data.organizationId is string);
      allow update: if hasPlatformAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.personId == resource.data.personId
            && request.resource.data.organizationId == resource.data.organizationId);
      allow delete: if false;
    }

    match /roleTemplates/{roleId} {
      allow read: if accountActive() && sameOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /roleAssignments/{assignmentId} {
      allow read: if accountActive()
        && (sameOrg(resource.data) || resource.data.personId == personId());
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /permissionOverrides/{overrideId} {
      allow read: if accountActive()
        && (sameOrg(resource.data) || resource.data.personId == personId());
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /teamMemberships/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /organizationalPositionAssignments/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /oversightAssignments/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /auditLogs/{logId} {
      allow read: if canReadOrg(resource.data) && hasPlatformAdmin();
      allow create: if accountActive() && sameOrg(request.resource.data);
      allow update, delete: if false;
    }

    match /ministries/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /teams/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /calendarEvents/{id} {
      allow read: if canReadOrg(resource.data);
      allow create, update: if isOrgMember() && sameOrg(request.resource.data);
      allow delete: if false;
    }

    match /formDefinitions/{id} {
      allow read: if canReadOrg(resource.data);
      allow write: if canWriteOrgAdmin(request.resource.data);
    }

    match /newcomerJourneys/{id} {
      allow read: if canReadOrg(resource.data);
      allow create, update: if isOrgMember() && sameOrg(request.resource.data);
      allow delete: if false;
    }

    match /followUpAssignments/{id} {
      allow read: if canReadOrg(resource.data);
      allow create, update: if isOrgMember() && sameOrg(request.resource.data);
      allow delete: if false;
    }

    match /followUpReports/{id} {
      allow read: if canReadOrg(resource.data);
      allow create: if isOrgMember()
        && sameOrg(request.resource.data)
        && request.resource.data.submittedByPersonId == personId();
      allow update: if isOrgMember()
        && sameOrg(resource.data)
        && (isReporter(resource.data) || hasPlatformAdmin());
      allow delete: if false;
    }

    match /newcomerAttendance/{id} {
      allow read: if canReadOrg(resource.data);
      allow create, update: if isOrgMember()
        && sameOrg(request.resource.data)
        && request.resource.data.recordedByPersonId == personId();
      allow delete: if false;
    }

    match /newcomerBioEntries/{id} {
      allow read: if canReadOrg(resource.data);
      allow create: if isOrgMember()
        && sameOrg(request.resource.data)
        && request.resource.data.addedByPersonId == personId();
      allow update: if isOrgMember()
        && sameOrg(resource.data)
        && (resource.data.addedByPersonId == personId() || hasPlatformAdmin());
      allow delete: if false;
    }

    match /tasks/{id} {
      allow read: if canReadOrg(resource.data)
        && (resource.data.assigneePersonId == personId() || hasPlatformAdmin());
      allow create, update: if isOrgMember() && sameOrg(request.resource.data);
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read: if canReadOrg(resource.data)
        && resource.data.recipientPersonId == personId();
      allow create: if isOrgMember() && sameOrg(request.resource.data);
      allow update: if accountActive()
        && resource.data.recipientPersonId == personId();
      allow delete: if false;
    }

    match /membershipRecommendations/{id} {
      allow read: if canReadOrg(resource.data);
      allow create: if isOrgMember()
        && sameOrg(request.resource.data)
        && request.resource.data.submittedByPersonId == personId();
      allow update: if isOrgMember() && sameOrg(resource.data);
      allow delete: if false;
    }

    // Public intake: create-only with required consent + org + names.
    // No reads for anonymous users. Leaders process via authenticated desk.
    match /publicRegistrations/{id} {
      allow create: if request.resource.data.keys().hasAll([
          'organizationId',
          'firstName',
          'lastName',
          'consent',
          'registrationSource',
          'status'
        ])
        && request.resource.data.consent == true
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.organizationId is string
        && request.resource.data.status in [
          'registration_pending',
          'duplicate_review_required'
        ];
      allow read, update: if isOrgMember() && sameOrg(resource.data);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
